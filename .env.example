IS_SERVERLESS=false

ALLOWED_ORIGINS=https://seu-app.vercel.app,https://www.seudominio.com.br,http://localhost:8081

# ============================================================
# SENDGRID CREDENTIALS
# (send automated email)
# ============================================================
SENDGRID_API_KEY=SG.sua_api_key_aqui
SENDER_EMAIL_VERIFICADO=seuemail@gmail.com

# ============================================================
# STRIPE
# ============================================================
STRIPE_SECRET_KEY=sk_test_sua_stripe_key_aqui

# ============================================================
# DATABASE CONFIGURATION - Choose one strategy below
# ============================================================

# Development Local (Docker) - Postgres
ENVIRONMENT=development
SEQUELIZE_DB_NAME=delbicos
SEQUELIZE_DB_USER=delbicos
SEQUELIZE_DB_PASS=postgres123
SEQUELIZE_HOST=localhost
SEQUELIZE_PORT=5432
SEQUELIZE_DIALECT=postgres

# ============================================================
# OPTIONAL DATABASE FLAGS
# ============================================================
DB_LOGGING=false  # Set to "true" to log SQL queries

# ============================================================
# AUTHENTICATION
# ============================================================
SECRET_KEY=sua_chave_secreta_super_segura_aqui
EXPIRES_IN=24h

# ============================================================
# FILE UPLOAD / STORAGE
# ============================================================
IMGBB_API_KEY=sua_api_key_aqui

# ============================================================
# MONITORING & LOGGING
# ============================================================
LOGTAIL_TOKEN=seu_token_logtail_aqui
LOG_LEVEL=info

# ============================================================
# EXTERNAL SERVICES
# ============================================================
# MongoDB Docker Local
MONGODB_URI=mongodb://localhost:27017/logs_db

# ============================================================
# AWS
# ============================================================
AWS_REGION_CW=us-east-1
AWS_ACCESS_KEY_ID_CW=sua_access_key_id
AWS_SECRET_ACCESS_KEY_CW=sua_secret_access_key
AWS_SESSION_TOKEN_CW=seu_session_token_se_necessario
CLOUDWATCH_LOG_GROUP=/seu-projeto/backend
CLOUDWATCH_LOG_STREAM=backend-local
ENABLE_CLOUDWATCH=false