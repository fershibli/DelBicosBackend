# ============================================================
# DATABASE CONFIGURATION - Choose one strategy below
# ============================================================

# Development Local (Docker) - MySQL

ENVIRONMENT=development
SEQUELIZE_DB_NAME=delbicos_db
SEQUELIZE_DB_USER=root
SEQUELIZE_DB_PASS=password123
SEQUELIZE_HOST=localhost
SEQUELIZE_PORT=3306
SEQUELIZE_DIALECT=mysql

# AWS RDS Production (MySQL)

# ENVIRONMENT=production
# SEQUELIZE_DB_NAME=seu_database_rds
# SEQUELIZE_DB_USER=admin
# SEQUELIZE_DB_PASS=sua_senha_super_segura
# SEQUELIZE_HOST=seu-rds-endpoint.abc123.us-east-1.rds.amazonaws.com
# SEQUELIZE_PORT=3306
# SEQUELIZE_DIALECT=mysql

# Neon Postgres Production

# ENVIRONMENT=production
# DATABASE_URL=postgresql://user:password@host.neon.tech/dbname
# SEQUELIZE_DIALECT=postgres

# ============================================================
# OPTIONAL DATABASE FLAGS
# ============================================================
DB_LOGGING=false  # Set to "true" to log SQL queries

# ============================================================
# AUTHENTICATION
# ============================================================
SECRET_KEY=sua_chave_secreta_super_segura_aqui
EXPIRES_IN=24h

# ============================================================
# FILE UPLOAD / STORAGE
# ============================================================
IMGBB_API_KEY=sua_api_key_aqui

# ============================================================
# MONITORING & LOGGING
# ============================================================
LOGTAIL_TOKEN=seu_token_logtail_aqui
LOG_LEVEL=info

# ============================================================
# EXTERNAL SERVICES
# ============================================================
MONGODB_URI=sua_conexao_mongodb_aqui